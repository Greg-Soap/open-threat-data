TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

DRIVE_DISK=fs
LIMITER_STORE=database

# PostgreSQL connection URL (optional; when set, used as primary DB; otherwise SQLite)
# DATABASE_URL=postgresql://user:password@host:port/database

FROM_EMAIL='test@test.com'
NO_REPLY_EMAIL='noreply@test.com'

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend (Vite) – used for branding and footer
# VITE_APP_NAME=Open Threat Data
# VITE_APP_DESCRIPTION=OSINT and threat analysis platform
# VITE_SUPPORT_EMAIL=support@example.com

# Support email for server-side emails (e.g. contact links in mail templates)
# SUPPORT_EMAIL=support@example.com

# OSINT / Threat Intel (optional)
# VIRUSTOTAL_API_KEY=
# ABUSEIPDB_API_KEY=
# MALWAREBAZAAR_API_KEY=   # abuse.ch Auth-Key (free at https://auth.abuse.ch/)
# URLHAUS_API_KEY=         # abuse.ch Auth-Key (same as MalwareBazaar)
# GOOGLE_SAFEBROWSING_API_KEY=
# HIBP_API_KEY=            # Have I Been Pwned (free at https://haveibeenpwned.com/API/Key)
# GREYNOISE_API_KEY=
# OTX_API_KEY=             # AlienVault OTX (free at https://otx.alienvault.com/settings)